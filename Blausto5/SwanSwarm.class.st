"
A 180@180 pixels swan pixel art generated by ChatGPT free.
"
Class {
	#name : 'SwanSwarm',
	#superclass : 'B5Rect',
	#traits : 'BlaustoClickFocus',
	#classTraits : 'BlaustoClickFocus classTrait',
	#instVars : [
		'mout',
		'startNote',
		'ccValue'
	],
	#category : 'Blausto5-elPistolero',
	#package : 'Blausto5',
	#tag : 'elPistolero'
}

{ #category : 'positioning' }
SwanSwarm >> decrementPositionX [

	self positionX: self position x - 10
]

{ #category : 'positioning' }
SwanSwarm >> decrementPositionY [

	self positionY: self position y - 5
]

{ #category : 'positioning' }
SwanSwarm >> incrementPositionX [ 

self positionX: self position x + 10
]

{ #category : 'positioning' }
SwanSwarm >> incrementPositionY [

	self positionY: self position y + 5
]

{ #category : 'initialization' }
SwanSwarm >> initialize [

	| swanArray |
	super initialize.
	self mode: #corner.
	self extent: 1300 @ 300.
	self position: 0 @ 150.
	swanArray := (1 to: 6) collect: [ :i |
			             B5Image new
				             fromFilePath:
					             '/Users/domenicocipriani/MyStuff/coding/pbpistolero/swan.png';
				             positionX: 1000 - (i * 60) ].
	self initializeMidi.
	self initializeEvents.
	self onClickFocus.
	^ self addChildren: swanArray
]

{ #category : 'initialization' }
SwanSwarm >> initializeEvents [

	self onKeyDownNamed: #RIGHT do: [
			self incrementPositionX.
			mout playNote: startNote onChannel: 1.
			startNote := startNote + 1.
			mout sendCC: 50 withValue: ccValue onChannel: 1.
			ccValue := ccValue + 2 ].
	self onKeyDownNamed: #LEFT do: [
			self decrementPositionX.
			mout playNote: startNote onChannel: 1.
			startNote := startNote + 1.
			mout playNote: startNote onChannel: 1 ].
	self onKeyDownNamed: #DOWN do: [
			self incrementPositionY.
			mout sendCC: 40 withValue: ccValue onChannel: 1.
			ccValue := ccValue - 1 ].
	self onKeyDownNamed: #UP do: [
			self incrementPositionY.

			mout sendCC: 40 withValue: ccValue onChannel: 1.
			ccValue := ccValue + 1 ]
]

{ #category : 'initialization' }
SwanSwarm >> initializeMidi [

mout := MIDISender  new.
mout openWithDevice: 3.
startNote := 36.
ccValue := 0.
mout sendCC: 50 withValue:  100 onChannel: 1
]
